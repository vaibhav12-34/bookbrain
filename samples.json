{
    "description": "Sample test data for BookBrain API testing",
    
    "sample_upload_requests": [
        {
            "endpoint": "POST /api/books/upload/",
            "description": "Add a book by title search",
            "request_body": {
                "query": "The Great Gatsby",
                "search_type": "title"
            },
            "expected_response": {
                "message": "Successfully added X book(s). AI processing started.",
                "books": ["list of book objects"]
            }
        },
        {
            "endpoint": "POST /api/books/upload/",
            "description": "Add a book by ISBN",
            "request_body": {
                "query": "9780743273565",
                "search_type": "isbn"
            }
        }
    ],

    "sample_scrape_requests": [
        {
            "endpoint": "POST /api/books/scrape/",
            "description": "Bulk scrape Hindi literature",
            "request_body": {
                "topic": "Hindi literature Premchand",
                "max_results": 5
            }
        },
        {
            "endpoint": "POST /api/books/scrape/",
            "description": "Bulk scrape science fiction books",
            "request_body": {
                "topic": "science fiction",
                "max_results": 10
            }
        }
    ],

    "sample_questions": [
        {
            "endpoint": "POST /api/books/ask/",
