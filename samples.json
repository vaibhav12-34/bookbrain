            "description": "Library overview question",
            "request_body": {
                "question": "What books do you have in the library?"
            },
            "expected_response_fields": ["answer", "sources", "confidence", "matched_books", "recommendations"]
        },
        {
            "endpoint": "POST /api/books/ask/",
            "question": "Tell me about Godan by Premchand",
