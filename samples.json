            "request_body": {
                "question": "Tell me about Godan by Premchand"
            },
            "sample_answer": "Based on the books in the database: 'Godan,' a cornerstone of Hindi literature, is a powerful novel by Munshi Premchand that delves deep into the socio-economic realities of rural India in the early 20th century..."
        },
        {
            "endpoint": "POST /api/books/ask/",
            "question": "Recommend books similar to Godan",
            "description": "Recommendation query",
            "request_body": {
                "question": "Recommend books similar to Godan"
            },
            "sample_answer": "Based on your interest, you might enjoy these books: 1. Nirmala 2. Devdas 3. Kamayani..."
        },
        {
            "endpoint": "POST /api/books/ask/",
            "question": "What genres are available?",
            "description": "Genre exploration query",
            "request_body": {
                "question": "What genres are available?"
            }
        },
        {
            "endpoint": "POST /api/books/ask/",
            "question": "Summarize the most popular book",
            "description": "Summary request query",
            "request_body": {
                "question": "Summarize the most popular book"
            }
        }
